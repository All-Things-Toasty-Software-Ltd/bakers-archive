<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="bakers_archive_core_tag_tree" model="ir.ui.view">
        <field name="name">bakers_archive.core.tag.list</field>
        <field name="model">bakers_archive.core.tag</field>
        <field name="arch" type="xml">
            <list>
                <field name="tag"/>
            </list>
        </field>
    </record>

    <record id="bakers_archive_core_tag_action" model="ir.actions.act_window">
        <field name="name">Tags</field>
        <field name="res_model">bakers_archive.core.tag</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>