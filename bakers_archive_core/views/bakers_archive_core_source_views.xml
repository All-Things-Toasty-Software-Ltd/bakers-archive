<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="bakers_archive_core_source_tree" model="ir.ui.view">
        <field name="name">bakers_archive.core.source.list</field>
        <field name="model">bakers_archive.core.source</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="type"/>
                <field name="url"/>
            </list>
        </field>
    </record>

    <record id="bakers_archive_core_source_action" model="ir.actions.act_window">
        <field name="name">Sources</field>
        <field name="res_model">bakers_archive.core.source</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>