<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="bakers_archive_core_recipe_tree" model="ir.ui.view">
        <field name="name">bakers_archive.core.recipe.list</field>
        <field name="model">bakers_archive.core.recipe</field>
        <field name="arch" type="xml">
            <list>
                <field name="active"/>
                <field name="name"/>
                <field name="origins"/>
                <field name="languages"/>
                <field name="tags"/>
            </list>
        </field>
    </record>

    <record id="bakers_archive_core_recipe_action" model="ir.actions.act_window">
        <field name="name">Recipes</field>
        <field name="res_model">bakers_archive.core.recipe</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>