<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="bakers_archive_core_license_tree" model="ir.ui.view">
        <field name="name">bakers_archive.core.license.list</field>
        <field name="model">bakers_archive.core.license</field>
        <field name="arch" type="xml">
            <list>
                <field name="license"/>
                <field name="short_name"/>
            </list>
        </field>
    </record>

    <record id="bakers_archive_core_license_action" model="ir.actions.act_window">
        <field name="name">Licenses</field>
        <field name="res_model">bakers_archive.core.license</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>