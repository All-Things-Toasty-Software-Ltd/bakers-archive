<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="bakers_archive_core_origin_tree" model="ir.ui.view">
        <field name="name">bakers_archive.core.origin.list</field>
        <field name="model">bakers_archive.core.origin</field>
        <field name="arch" type="xml">
            <list>
                <field name="country"/>
            </list>
        </field>
    </record>

    <record id="bakers_archive_core_origin_action" model="ir.actions.act_window">
        <field name="name">Origins</field>
        <field name="res_model">bakers_archive.core.origin</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>