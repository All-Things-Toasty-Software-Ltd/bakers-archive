<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="bakers_archive_core_recipe_instruction_tree" model="ir.ui.view">
        <field name="name">bakers_archive.core.recipe.instruction.list</field>
        <field name="model">bakers_archive.core.recipe.instruction</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence"/>
                <field name="description"/>
                <field name="time"/>
            </list>
        </field>
    </record>

    <record id="bakers_archive_core_recipe_instruction_action" model="ir.actions.act_window">
        <field name="name">Recipe Instructions</field>
        <field name="res_model">bakers_archive.core.recipe.instruction</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>